-- Serialization helpers (safe)
local function valueToString(D)
    if type(D) == "table" then
        if D.Type == "Color3" then
            return string.format("RGB: %d, %d, %d", math.floor(D.R * 255), math.floor(D.G * 255), math.floor(D.B * 255))
        elseif D.Type == "EnumItem" then
            return tostring(D.Name)
        end
        for D, f in pairs(D) do
            if type(f) == "string" or type(f) == "number" then
                return tostring(f)
            end
        end
        return "None"
    end
    return D ~= nil and tostring(D) or "None"
end

local function serialize(D)
    if typeof(D) == "Color3" then
        return {
            Type = "Color3";
            R = D.R;
            G = D.G,
            B = D.B
        }
    elseif typeof(D) == "EnumItem" then
        return {
            Type = "EnumItem";
            EnumType = tostring(D.EnumType);
            Name = D.Name
        }
    elseif typeof(D) == "table" then
        local f = {}
        for D, F in pairs(D) do
            f[D] = serialize(F)
        end
        return f
    end
    return D
end

local function deserialize(D)
    if type(D) == "table" then
        if D.Type == "Color3" then
            return Color3.new(D.R, D.G, D.B)
        elseif D.Type == "EnumItem" then
            local f, F = pcall(function()
                return Enum[D.EnumType][D.Name]
            end)
            return f and F or nil
        else
            local f = {}
            for D, F in pairs(D) do
                f[D] = deserialize(F)
            end
            return f
        end
    end
    return D
end

