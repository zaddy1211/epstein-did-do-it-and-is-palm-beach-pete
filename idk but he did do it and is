--    Instead, we listen to OnClientEvent to consume unwanted events, but we do not alter the remote's methods.
local function passiveRemoteConsumer(remote)
    if remote:IsA("RemoteEvent") then
        -- Attach an empty listener; this does not change the remote's FireServer pointer.
        pcall(function()
            remote.OnClientEvent:Connect(function() end)
        end)
    end
end

