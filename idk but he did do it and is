-- 5) Physics – no part resizing, no Heartbeat. Use Stepped with 0.1s interval, only distance check.
local PhysicsHandler = {}
PhysicsHandler._conn = nil

local function predictBallPosition(ball, dt)
    local pos = ball.Position
    local vel = ball.AssemblyLinearVelocity
    local grav = Vector3.new(0, workspace.Gravity, 0)
    return pos + vel * dt + 0.5 * grav * dt * dt
end

function PhysicsHandler.start(player, config)
    config = config or { ReachDistance = 6.5 }
    if PhysicsHandler._conn then
        PhysicsHandler._conn:Disconnect()
        PhysicsHandler._conn = nil
    end
    local RunService = game:GetService("RunService")
    local accum = 0
    PhysicsHandler._conn = RunService.Stepped:Connect(function(_, dt)
        accum = accum + dt
        if accum < 0.1 then return end
        accum = 0
        pcall(function()
            local char = player.Character
            if not char then return end
            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then return end
            local ball = workspace:FindFirstChild("Football")
            if not ball then return end
            local predicted = predictBallPosition(ball, 0.05)
            local dist = (root.Position - predicted).Magnitude
            if dist <= config.ReachDistance then
                -- Here you would normally trigger a catch – but do it via a RemoteEvent that already exists,
                -- do not modify physics. We simply set a flag; actual catch logic is external.
                -- For demonstration, we just store the fact.
                LyraState.lastCatch = tick()
            end
        end)
    end)
end

function PhysicsHandler.stop()
    if PhysicsHandler._conn then
        PhysicsHandler._conn:Disconnect()
        PhysicsHandler._conn = nil
    end
end

-- 6) Signal cleaner – use simple budgeted loops with task.wait, not hooking RunService.
local SignalCleaner = {}
SignalCleaner._tasks = {}

function SignalCleaner.startBudgetedLoop(interval, callback, jitterPercent)
    jitterPercent = jitterPercent or 0.02
    local running = true
    local taskId = #SignalCleaner._tasks + 1
    SignalCleaner._tasks[taskId] = { running = true }
    task.spawn(function()
        while SignalCleaner._tasks[taskId].running do
            local jitter = 1.0 + (math.random() * 2 - 1) * jitterPercent
            local waitTime = interval * jitter
            task.wait(waitTime)
            pcall(callback)
        end
    end)
    return taskId
end

function SignalCleaner.stopLoop(taskId)
    if SignalCleaner._tasks[taskId] then
        SignalCleaner._tasks[taskId].running = false
        SignalCleaner._tasks[taskId] = nil
    end
end

function SignalCleaner.stopAll()
    for id, _ in pairs(SignalCleaner._tasks) do
        SignalCleaner._tasks[id].running = false
        SignalCleaner._tasks[id] = nil
    end
end

